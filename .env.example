OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# Pinecone (free at app.pinecone.io — no expiry)
PINECONE_API_KEY=your-pinecone-api-key

# FastF1 cache — use /tmp for Streamlit Cloud (ephemeral is fine, just re-downloads when cold)
FASTF1_CACHE_PATH=/tmp/f1_cache

LOG_LEVEL=INFO
