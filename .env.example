OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# Qdrant Cloud (free at cloud.qdrant.io)
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# FastF1 cache — use /tmp for Streamlit Cloud (ephemeral is fine, just re-downloads when cold)
FASTF1_CACHE_PATH=/tmp/f1_cache

LOG_LEVEL=INFO
